
<style>
    .modal-footer{
        padding:12px;
    }
    .button{
        background-color: #f59e0b !important;
        border-color: #f59e0b !important;
        color:white;
    }
</style>
@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    <button class="btn-close" @onclick="Close"></button>
                </div>

                <div class="modal-body">
                    <h5 class="text-muted">@Message</h5>
                </div>

                    <div class="modal-footer">

                        @if (IsConfirm)
                        {
                           
                            <button class="btn button" @onclick="Close">Keep</button>
                        <button class="btn btn-danger" style="padding: 6px 18.3px;" @onclick="Confirm">Yes</button>
                        }
                        else
                        {
                            <button class="btn button" @onclick="Close">OK</button>
                        }
                </div>

            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public string Title { get; set; } = "Message";
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }

    [Parameter] public bool IsConfirm { get; set; }

    [Parameter] public EventCallback OnConfirm { get; set; }


    private async Task Confirm()
    {
        await OnConfirm.InvokeAsync();
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }
}