@page "/employees"
@inject IEmployeeService EmployeeService
@inject IDepartmentService DepartmentService
@inject IDesignationService DesignationService
@rendermode InteractiveServer

<style>
    .table-container {
        width: 100%;
        overflow-x: auto;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        background: white;
    }

        .employee-table th,
        .employee-table td {
            white-space: nowrap;
            vertical-align: middle;
        }
        .employee-table th.action-column {
            position: sticky;
            top: 0;
            left:0;
            z-index: 5;
            background: #f8f9fa;
        }

    .employee-table tbody tr {
        max-height: 40px !important;
    }

    .employee-table tbody td {
        padding: 4px 8px;
    }

    .emp-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid #f1f5f9;
        object-fit: cover;
    }

    .action-column {
        position: sticky;
        right: 0;
        background: white;
        min-width: 120px;
        text-align: center;
        box-shadow: -2px 0 4px rgba(0,0,0,0.05);
        z-index: 2;
    }

    .action-buttons {
        display: flex;
        justify-content: flex-end;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .edit-btn {
        background: #eef4ff;
        color: #f59e0b;
    }

        .edit-btn:hover {
            background: #dbe7ff;
        }

    .delete-btn {
        background: #fff1f2;
        color: #ef4444;
    }

        .delete-btn:hover {
            background: #ffe4e6;
        }

    .badge {
        font-size: 12px;
        padding: 6px 8px;
        border-radius: 6px;
        font-weight: 500;
    }

    .active-badge {
        background: #dcfce7;
        color: #16a34a;
    }

    .inactive-badge {
        background: #fee2e2;
        /* color: #dc2626; */
        color:black;
    }

    .page-number {
        margin: 0 6px;
        cursor: pointer;
        color: #1f2a44;
    }

        .page-number:hover {
            color: #f59e0b;
        }

    .active-page {
        font-weight: 600;
        color: #f59e0b;
    }

    .page-nav {
        margin: 0 8px;
        cursor: pointer;
        color: #1f2a44;
    }
    .table-footer td {
        border-bottom: 0px;
    }

    .table-footer tr td:first-child {
        border-bottom-left-radius: 10px;
    }

    .table-footer tr td:last-child {
        border-bottom-right-radius: 10px;
    }
</style>
<style>
    .filter-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 15px;
        align-items: center;
        justify-content:end;
    }

    .filter-select {
        width: 180px;
    }

    .filter-date {
        width: 170px;
    }

    .filter-reset {
        border: 1px solid #e5e7eb;
    }

        .filter-reset:hover {
            background: #f59e0b;
            color: white;
        }
</style>
<div class="top-header">

    <div class="top-title">
        <h3>Employees</h3>
    </div>

    <div class="top-actions">

     <input type="text"
       class="search-input"
       placeholder="Search employees..."
       @bind="searchText"
       @oninput="Search" />

            <button class="btn-create" @onclick="OpenModalAsync" disabled="@isLoading">

                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span> 
                <span>Loading..</span>
                }
                else
                {
                    <span>+ Create</span>
                }

            </button>

    </div>

</div>
<div class="filter-bar">

    <select class="form-select filter-select">
        <option value="">Department</option>
        <option>IT</option>
        <option>HR</option>
        <option>Finance</option>
    </select>

    <select class="form-select filter-select">
        <option value="">Designation</option>
        <option>Software Developer</option>
        <option>HR Manager</option>
    </select>

    <select class="form-select filter-select">
        <option value="">Status</option>
        <option>Active</option>
        <option>Inactive</option>
    </select>

    <input type="date" class="form-control filter-date">

    <button class="btn btn-light filter-reset">
        <i class="bi bi-arrow-clockwise"></i> Reset
    </button>

</div>
@if (employees == null)
{
    <p><em>Loading...</em></p>
}
else
{
<div class="table-container">
<table class="table employee-table table-hover align-middle mb-0">

            <thead class="table-light">
                <tr>
                    <th style="width:60px"></th>
                    <th>EmpCode</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Mobile</th>
                    <th>Hire Date</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th>Salary</th>
                    <th class="text-end action-column">Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var emp in employees)
                {
                    <tr>

                        <td>
                            <img src="@(string.IsNullOrEmpty(emp.Image) ? "/default/avtar.png" : emp.Image)"
                                 class="emp-avatar" />
                        </td>
                        <td>
                            @emp.EmpCode
                        </td>
                        <td>
                            @emp.FirstName @emp.LastName
                        </td>

                        <td>@emp.Email</td>

                        <td>
                            @emp.PhoneNumber
                            @* @if (!string.IsNullOrWhiteSpace(emp.AlternatePhoneNumber))
                            {
                                <br />
                                <small class="text-muted">@emp.AlternatePhoneNumber</small>
                            } *@
                        </td>

                        <td>@emp.HireDate?.ToString("dd MMM yyyy")</td>

                        <td>@emp.Department?.Name</td>

                        <td>@emp.Designation?.Name</td>

                        <td class="fw-semibold">₹ @emp.Salary.ToString("N0")</td>

                        <td class="text-end action-column">
                                <div class="d-flex justify-content-end align-items-center gap-2">
                                        <span class="badge @(emp.IsActive ? "active-badge" : "inactive-badge")">@(emp.IsActive ? "Active" : "Inactive")</span>
                            <div class="action-buttons">

                                <button class="btn btn-icon edit-btn"
                                        title="Edit"
                                        style="border-radius: 6px 0px 0px 6px;"
                                        @onclick="() => EditEmployee(emp.Id)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="btn btn-icon delete-btn"
                                        title="Delete"
                                        style="border-radius: 0px 6px 6px 0px;"
                                        @onclick="() => DeleteEmployee(emp.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </div>
                            </div>
                        </td>

                    </tr>
                }

            </tbody>
            <tfoot class="table-light table-footer">
                <tr>
                    <td colspan="10">
                        <div class="d-flex justify-content-end table-pagination">

                            <span class="page-nav"
                                  @onclick="PreviousPage"
                                  style="@(HasPrevious ? "" : "pointer-events:none;opacity:0.4")">
                                <i class="bi bi-chevron-left"></i>
                            </span>

                            @for (int i = 1; i <= Math.Ceiling((double)totalCount / pageSize); i++)
                            {
                                var index = i;
                                <span class="page-number @(pageNumber == index ? "active-page" : "")"
                                      @onclick="() => GoToPage(index)">
                                    @index
                                </span>
                            }

                            <span class="page-nav"
                                  @onclick="NextPage"
                                  style="@(HasNext ? "" : "pointer-events:none;opacity:0.4")">
                                <i class="bi bi-chevron-right"></i>
                            </span>

                        </div>
                    </td>
                </tr>
            </tfoot>
        </table>
</div>        
}
<CreateEditEmployee Employee="selectedEmployee"Departments="departments"Designations="designations" Show="show"
                    OnClose="CloseModal"
                    OnSaved="HandleSaved" />


@code {
    private bool show;
    private bool isLoading;
    private List<EmployeeDto> employees = new();
    private EmployeeDto selectedEmployee = new();
    private string searchText = "";
    private CancellationTokenSource cts { get; set; } = new();
    private int pageNumber = 1;
    private int pageSize = 10;
    private int totalCount;
    private List<DepartmentDto> departments = new();
    private List<DesignationDto> designations = new();



    private bool HasPrevious => pageNumber > 1;

    private bool HasNext => pageNumber * pageSize < totalCount;

    protected override async Task OnInitializedAsync()
    {
        departments = await DepartmentService.GetAllAsync();
        designations = await DesignationService.GetAllDesignationsAsync();
        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        var result = await EmployeeService.GetAllEmployeesAsync(pageNumber, pageSize,searchText);

        employees = result.Items;
        totalCount = result.TotalCount;
        StateHasChanged();
    }


    private async Task EditEmployee(int id)
    {
        var emp = await EmployeeService.GetEmployeeByIdAsync(id);

        if (emp != null)
            selectedEmployee = emp;
        show = true;
    }
    private async Task HandleSaved()
    {
        show = false;

        await LoadEmployees();
    }
    private async Task DeleteEmployee(int id)
    {
       
            await EmployeeService.DeleteEmployeeAsync(id);
            await LoadEmployees();
        
    }
    private async Task Search(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        cts.Cancel();
        cts = new CancellationTokenSource();

        try
        {
            await Task.Delay(500, cts.Token);
            pageNumber = 1;
            await LoadEmployees();
        }
        catch (TaskCanceledException)
        {
        }
    }
    private async Task OpenModalAsync()
    {
        isLoading = true;

        await Task.Delay(300); 

        ShowModal();

        isLoading = false;
    }
    private void ShowModal()
    {
        Console.WriteLine("Create button clicked");
        selectedEmployee = new EmployeeDto();
        show = true;
    }
    private void CloseModal()
    {
        show = false;
    }

    private async Task NextPage()
    {
        pageNumber++;
        await LoadEmployees();
    }

    private async Task PreviousPage()
    {
        pageNumber--;
        await LoadEmployees();
    }
    private async Task GoToPage(int page)
    {
        pageNumber = page;
        await LoadEmployees();
    }
}