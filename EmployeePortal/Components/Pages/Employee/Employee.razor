@page "/employees"
@inject IEmployeeService EmployeeService
@inject IDepartmentService DepartmentService
@inject IDesignationService DesignationService
@rendermode InteractiveServer

<style>
    .table-container {
        width: 100%;
        overflow-x: auto;
    }

    .employee-table {
        min-width: 1100px;
    }

        .employee-table th,
        .employee-table td {
            white-space: nowrap;
            vertical-align: middle;
        }
    .employee-table table {
        min-width: 1000px;
    }

        .employee-table th.action-column {
            position: sticky;
            right: 0;
            background: #f8f9fa;
        }
    .emp-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
    }

    .action-column {
        position: sticky;
        right: 0;
        background: white;
        min-width: 120px;
        text-align: center;
        box-shadow: -2px 0 4px rgba(0,0,0,0.05);
        z-index: 2;
    }

    .action-buttons {
        display: flex;
        justify-content: flex-end;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .edit-btn {
        background: #eef4ff;
        color: #f59e0b;
    }

        .edit-btn:hover {
            background: #dbe7ff;
        }

    .delete-btn {
        background: #fff1f2;
        color: #ef4444;
    }

        .delete-btn:hover {
            background: #ffe4e6;
        }
</style>
<div class="top-header">

    <div class="top-title">
        <h3>Employees</h3>
    </div>

    <div class="top-actions">

     <input type="text"
       class="search-input"
       placeholder="Search employees..."
       @bind="searchText"
       @oninput="Search" />

            <button class="btn-create" @onclick="OpenModalAsync" disabled="@isLoading">

                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span> 
                <span>Loading..</span>
                }
                else
                {
                    <span>+ Create</span>
                }

            </button>

    </div>

</div>
@if (employees == null)
{
    <p><em>Loading...</em></p>
}
else
{
<div class="table-container">
<table class="table employee-table table-hover align-middle mb-0">

            <thead class="table-light">
                <tr>
                    <th style="width:60px"></th>
                    <th>EmpCode</th>
                    <th>Employee</th>
                    <th>Email</th>
                    <th>Mobile</th>
                    <th>Hire Date</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th>Salary</th>
                    <th class="text-end action-column">Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var emp in employees)
                {
                    <tr>

                        <td>
                            <img src="@(string.IsNullOrEmpty(emp.Image) ? "/default/avtar.png" : emp.Image)"
                                 class="emp-avatar" />
                        </td>
                        <td>
                            @emp.EmpCode
                        </td>
                        <td>
                            @emp.FirstName @emp.LastName
                        </td>

                        <td>@emp.Email</td>

                        <td>
                            @emp.PhoneNumber
                            @if (!string.IsNullOrWhiteSpace(emp.AlternatePhoneNumber))
                            {
                                <br />
                                <small class="text-muted">@emp.AlternatePhoneNumber</small>
                            }
                        </td>

                        <td>@emp.HireDate?.ToString("dd MMM yyyy")</td>

                        <td>@emp.Department?.Name</td>

                        <td>@emp.Designation?.Name</td>

                        <td class="fw-semibold">₹ @emp.Salary.ToString("N0")</td>

                        <td class="text-end action-column">

                            <div class="action-buttons">

                                <button class="btn btn-icon edit-btn"
                                        title="Edit"
                                        style="border-radius: 10px 0px 0px 10px;"
                                        @onclick="() => EditEmployee(emp.Id)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="btn btn-icon delete-btn"
                                        title="Delete"
                                        style="border-radius: 0px 10px 10px 0px;"
                                        @onclick="() => DeleteEmployee(emp.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>
        </div>        
    <div class="mt-3">
        <button class="btn btn-primary me-2" @onclick="PreviousPage" disabled="@(!HasPrevious)">
            Previous
        </button>

        <button class="btn btn-primary" @onclick="NextPage" disabled="@(!HasNext)">
            Next
        </button>
    </div>
}
<CreateEditEmployee Employee="selectedEmployee"Departments="departments"Designations="designations" Show="show"
                    OnClose="CloseModal"
                    OnSaved="HandleSaved" />


@code {
    private bool show;
    private bool isLoading;
    private List<EmployeeDto> employees = new();
    private EmployeeDto selectedEmployee = new();
    private string searchText = "";
    private CancellationTokenSource cts { get; set; } = new();
    private int pageNumber = 1;
    private int pageSize = 10;
    private int totalCount;
    private List<DepartmentDto> departments = new();
    private List<DesignationDto> designations = new();



    private bool HasPrevious => pageNumber > 1;

    private bool HasNext => pageNumber * pageSize < totalCount;

    protected override async Task OnInitializedAsync()
    {
        departments = await DepartmentService.GetAllAsync();
        designations = await DesignationService.GetAllDesignationsAsync();
        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        var result = await EmployeeService.GetAllEmployeesAsync(pageNumber, pageSize,searchText);

        employees = result.Items;
        totalCount = result.TotalCount;
    }


    private async Task EditEmployee(int id)
    {
        var emp = await EmployeeService.GetEmployeeByIdAsync(id);

        if (emp != null)
            selectedEmployee = emp;
        show = true;
    }
    private async Task HandleSaved()
    {
        show = false;

        await LoadEmployees();
    }
    private async Task DeleteEmployee(int id)
    {
       
            await EmployeeService.DeleteEmployeeAsync(id);
            await LoadEmployees();
        
    }
    private async Task Search(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";

        cts.Cancel();
        cts = new CancellationTokenSource();

        try
        {
            await Task.Delay(500, cts.Token);
            pageNumber = 1;
            await LoadEmployees();
        }
        catch (TaskCanceledException)
        {
        }
    }
    private async Task OpenModalAsync()
    {
        isLoading = true;

        await Task.Delay(300); 

        ShowModal();

        isLoading = false;
    }
    private void ShowModal()
    {
        Console.WriteLine("Create button clicked");
        selectedEmployee = new EmployeeDto();
        show = true;
    }
    private void CloseModal()
    {
        show = false;
    }

    private async Task NextPage()
    {
        pageNumber++;
        await LoadEmployees();
    }

    private async Task PreviousPage()
    {
        pageNumber--;
        await LoadEmployees();
    }
}